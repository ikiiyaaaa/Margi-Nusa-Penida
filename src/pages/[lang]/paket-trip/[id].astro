---
import MainLayout from '../../../layouts/MainLayout.astro';
import { packages } from '../../../data/packages';
import { useTranslations } from '../../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

import type { Package } from '../../../data/packages';

export function getStaticPaths() {
  const paths: any[] = [];
  ['id', 'en'].forEach(lang => {
    packages.forEach(pkg => {
      paths.push({
        params: { lang, id: pkg.id },
        props: { pkg },
      });
    });
  });
  return paths;
}

const { lang } = Astro.params;
const pkg = Astro.props.pkg as Package;
const t = useTranslations(lang as any);
const l = (path: string) => getRelativeLocaleUrl(lang as any, path);
---

<MainLayout title={`${pkg.name[lang as 'id' | 'en']} - Margi Nusa Penida`} lang={lang}>
  <div class="pt-40 pb-24">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-5xl mx-auto">
        
        <!-- Navigation & Breadcrumbs -->
        <a href={l('/paket-trip')} class="inline-flex items-center gap-2 text-ocean-600 font-bold mb-10 hover:text-ocean-700 transition-colors group">
          <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          {t('detail.back')}
        </a>

        <!-- Main Hero Image (Top) -->
        <div class="relative w-full aspect-[21/9] md:aspect-[24/10] rounded-[2rem] overflow-hidden shadow-2xl mb-12">
          <img src={pkg.image} alt={pkg.name[lang as 'id' | 'en']} class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-gray-900/40 to-transparent"></div>
          <div class="absolute bottom-8 left-8">
            <span class="inline-block px-4 py-2 text-xs font-bold uppercase tracking-widest bg-white/90 backdrop-blur-md text-ocean-600 rounded-full shadow-lg mb-4">
              {pkg.category.replace('-', ' ')}
            </span>
            <h1 class="text-4xl md:text-6xl font-bold font-['Poppins'] text-white drop-shadow-md">{pkg.name[lang as 'id' | 'en']}</h1>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Left Column (Info) -->
          <div class="lg:col-span-2 space-y-12">
            
            <!-- Combined Overview & Info Card -->
            <section class="bg-white border border-gray-100 rounded-[2rem] p-4 md:p-10 shadow-xl">
              <details open class="group">
                <summary class="flex items-center justify-between cursor-pointer list-none">
                  <h2 class="text-2xl font-bold text-gray-900">{t('detail.about')}</h2>
                  <div class="w-10 h-10 rounded-full bg-ocean-50 flex items-center justify-center text-ocean-600 group-open:rotate-180 transition-transform">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </summary>
                
                <div class="mt-8 space-y-12">
                  <!-- Description -->
                  <div class="prose prose-lg text-gray-600 max-w-none">
                    <p>{pkg.description[lang as 'id' | 'en']}</p>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 border-t border-gray-100 pt-10">
                    <!-- Destinations -->
                    <div>
                      <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-ocean-50 flex items-center justify-center text-ocean-600">
                          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          </svg>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900">{t('detail.destinations')}</h3>
                      </div>
                      <ul class="space-y-4">
                        {pkg.destinations.map((dest: string) => (
                          <li class="flex items-center gap-3 text-gray-700 font-medium">
                            <div class="w-1.5 h-1.5 rounded-full bg-ocean-400"></div>
                            {dest}
                          </li>
                        ))}
                      </ul>
                    </div>

                    <!-- Facilities -->
                    <div>
                      <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-ocean-50 flex items-center justify-center text-ocean-600">
                          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                          </svg>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900">{t('detail.facilities')}</h3>
                      </div>
                      <ul class="space-y-4">
                        {pkg.facilities[lang as 'id' | 'en'] && pkg.facilities[lang as 'id' | 'en'].map((facility: string) => (
                          <li class="flex items-center gap-3 text-gray-700 font-medium">
                            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            {facility}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </div>
              </details>
            </section>

            <!-- Include / Exclude Card -->
            <section class="bg-white border border-gray-100 rounded-[2rem] p-4 md:p-8 shadow-xl">
              <details class="group">
                <summary class="flex items-center justify-between cursor-pointer list-none">
                  <h2 class="text-2xl font-bold text-gray-900">{t('detail.includes')}</h2>
                  <div class="w-10 h-10 rounded-full bg-ocean-50 flex items-center justify-center text-ocean-600 group-open:rotate-180 transition-transform">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </summary>
                <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div>
                    <h3 class="text-xl font-bold mb-6 text-ocean-600 flex items-center gap-2">
                       <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                      </svg>
                      {t('detail.includes')}
                    </h3>
                    <ul class="space-y-3">
                      {pkg.includes[lang as 'id' | 'en'] && pkg.includes[lang as 'id' | 'en'].map((item: string) => (
                        <li class="flex items-start gap-2 text-gray-600 font-medium">
                          <svg class="w-5 h-5 text-ocean-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                          </svg>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h3 class="text-xl font-bold mb-6 text-red-500 flex items-center gap-2">
                      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                      {t('detail.excludes')}
                    </h3>
                    <ul class="space-y-3">
                      {pkg.excludes[lang as 'id' | 'en'] && pkg.excludes[lang as 'id' | 'en'].map((item: string) => (
                        <li class="flex items-start gap-2 text-gray-400">
                          <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                          </svg>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </details>
            </section>
          </div>

          <!-- Right Column (CTA Sidebar) -->
          <div class="space-y-8">
            <div class="bg-white border border-gray-100 rounded-[2rem] p-8 shadow-xl sticky top-32">
              <div class="mb-4">
                <p class="text-gray-500 font-medium mb-1 text-sm">{t('detail.start_from')}</p>
                <div class="text-4xl font-bold text-gray-900 mb-1">{pkg.price}</div>
                <p class="text-ocean-600 font-bold">{pkg.pax}</p>
              </div>

              <div class="h-px bg-gray-100 w-full my-6"></div>

              <ul class="space-y-4 mb-8">
                <li class="flex items-center gap-3 text-gray-600 text-sm italic">
                  <svg class="w-5 h-5 text-ocean-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {t('detail.duration')}
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm italic">
                  <svg class="w-5 h-5 text-ocean-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                  </svg>
                  {t('detail.payment')}
                </li>
              </ul>

              <a 
                href={`https://wa.me/6285117480447?text=Halo Margi Nusa Penida, saya ingin memesan ${pkg.name[lang as 'id' | 'en']}.`} 
                target="_blank"
                class="inline-block w-full text-center bg-ocean-600 text-white font-bold py-5 px-8 rounded-2xl hover:bg-ocean-700 transition-all shadow-xl shadow-ocean-600/30 text-lg"
              >
                {t('detail.book_now')}
              </a>
              <p class="text-center text-gray-400 text-xs mt-4">
                {t('detail.instant_conf')}
              </p>
            </div>

            <!-- Custom Order Card -->
            <div class="bg-ocean-600 rounded-[2rem] p-8 text-white shadow-xl group hover:bg-ocean-700 transition-colors">
              <h4 class="text-xl font-bold mb-4">{t('detail.custom_title')}</h4>
              <p class="text-ocean-100 text-sm mb-6 leading-relaxed">
                {t('detail.custom_desc')}
              </p>
              <a 
                href="https://wa.me/6285117480447?text=Halo Margi Nusa Penida, saya ingin tanya paket custom untuk jumlah pax berbeda / request destinasi." 
                target="_blank"
                class="inline-flex items-center justify-center w-full px-6 py-4 bg-white text-ocean-600 font-bold rounded-2xl hover:bg-ocean-50 transition-colors gap-2"
              >
                {t('detail.custom_cta')}
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>

            <!-- Need Help Box -->
            <div class="bg-gray-50 border border-gray-100 rounded-[2rem] p-8">
              <h4 class="font-bold text-gray-900 mb-2">{t('detail.help_title')}</h4>
              <p class="text-gray-600 text-sm mb-4">{t('detail.help_desc')}</p>
              <a href={l('/contact-us')} class="text-ocean-600 font-bold text-sm hover:underline flex items-center gap-2">
                {t('detail.help_cta')}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>

        </div>

      </div>
    </div>
  </div>
</MainLayout>
