---
import MainLayout from '../../../layouts/MainLayout.astro';
import ContactSection from '../../../components/home/ContactSection.astro';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'id' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<MainLayout title={t('nav.contact')} lang={lang}>
  <div class="pt-8 pb-12">
    <ContactSection 
      lang={lang}
      headingSubtitle={t('contact.subtitle')}
      description={t('contact.desc')}
    />
  </div>
  
  <section class="w-full relative">
    <div class="absolute inset-x-0 top-0 h-10 bg-gradient-to-b from-white to-transparent z-10"></div>
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d126176.43853177897!2d115.457816155604!3d-8.730303867664687!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd271b12b252985%3A0xc07ce8fb464a0cd9!2sNusa%20Penida!5e0!3m2!1sen!2sid!4v1709400000000!5m2!1sen!2sid" 
      width="100%" 
      height="500" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      class="grayscale-[30%] hover:grayscale-0 transition-all duration-700"
    ></iframe>
  </section>
</MainLayout>
