---
import MainLayout from '../../layouts/MainLayout.astro';
import SectionHeading from '../../components/shared/SectionHeading.astro';
import WhyChooseUsSection from '../../components/home/WhyChooseUsSection.astro';
---

<MainLayout title="About Us">
  <!-- Hero About Section -->
  <section class="relative pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden bg-gray-900">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1518548419970-58e3b4079ab2?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" 
        alt="Nusa Penida Landscape" 
        class="w-full h-full object-cover opacity-40"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/60 to-transparent"></div>
    </div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10 text-center max-w-4xl">
      <span class="inline-block py-1 px-3 rounded-full bg-ocean-500/20 text-ocean-300 text-sm font-semibold tracking-wide uppercase mb-4 border border-ocean-500/30 backdrop-blur-md">
        Our Story
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-['Poppins'] text-white leading-tight mb-6">
        Your Gateway to the Wonders of Nusa Penida
      </h1>
      <p class="text-lg md:text-xl text-gray-300 font-light leading-relaxed">
        Margi Nusa Penida is a trusted travel and tour agency committed to providing seamless, comfortable, and unforgettable experiences across the beautiful islands of Nusa Penida.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <!-- Left: Text Content -->
        <div class="order-2 lg:order-1">
          <SectionHeading 
            title="A Journey Driven by Passion" 
            subtitle="Who We Are" 
            centered={false} 
          />
          
          <div class="space-y-6 text-gray-600 font-light leading-relaxed text-lg mt-8">
            <p>
              Born out of a deep love for the breathtaking landscapes and spiritual heritage of Nusa Penida, <strong class="text-gray-900 font-semibold">Margi Nusa Penida</strong> was established with a simple goal: to make discovering this island as easy and enjoyable as possible.
            </p>
            <p>
              We understand that traveling to a new island can sometimes be stressful to organize. Our dedicated team handles all the details—from comfortable transportation with experienced local driver-guides to fast boat tickets and specially curated meals.
            </p>
            <p>
              Whether you are seeking the pristine white sands of Kelingking Beach, or returning for a solemn spiritual journey (Tirta Yatra), we tailor every element of your trip to ensure comfort, affordability, and joy.
            </p>
          </div>
          
          <div class="grid grid-cols-2 gap-8 mt-12 pt-12 border-t border-gray-100">
            <div>
              <div class="text-4xl font-bold font-['Poppins'] text-ocean-600 mb-2">100%</div>
              <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Customer Satisfaction</p>
            </div>
            <div>
              <div class="text-4xl font-bold font-['Poppins'] text-sunset-500 mb-2">Local</div>
              <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Expertise & Guides</p>
            </div>
          </div>
        </div>
        
        <!-- Right: Image Mosaic -->
        <div class="order-1 lg:order-2 grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <img 
              src="https://images.unsplash.com/photo-1588880628359-25f0ad0869a4?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" 
              alt="Nusa Penida Scenery" 
              class="w-full h-64 object-cover rounded-3xl shadow-lg"
            />
            <img 
              src="https://images.unsplash.com/photo-1544644181-1484b3fdfc62?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" 
              alt="Temple in Nusa Penida" 
              class="w-full h-80 object-cover rounded-3xl shadow-lg"
            />
          </div>
          <div class="space-y-4 pt-12">
            <img 
              src="https://images.unsplash.com/photo-1552733407-5d5c46c3bb3b?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" 
              alt="Local Boat" 
              class="w-full h-80 object-cover rounded-3xl shadow-lg"
            />
            <div class="w-full h-64 bg-ocean-50 rounded-3xl p-8 flex flex-col justify-center border border-ocean-100">
              <svg class="w-12 h-12 text-ocean-500 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
              </svg>
              <h4 class="text-xl font-bold text-ocean-900 mb-2">Our Promise</h4>
              <p class="text-sm text-ocean-700">Safety, comfort, and memories that last a lifetime.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Re-use the Why Choose Us component from Home page -->
  <div class="bg-gray-50 border-t border-gray-100">
    <WhyChooseUsSection />
  </div>

  <!-- Call to Action -->
  <section class="py-24 bg-ocean-600 relative overflow-hidden">
    <!-- Decorative patterns -->
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="pattern-circles" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="2" fill="currentColor" />
          </pattern>
        </defs>
        <rect x="0" y="0" width="100%" height="100%" fill="url(#pattern-circles)" />
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-3xl">
      <h2 class="text-3xl md:text-5xl font-bold font-['Poppins'] text-white mb-6">Ready to Explore Paradise?</h2>
      <p class="text-ocean-100 text-lg mb-10 font-light">
        Book your preferred package today and let us handle the rest. We ensure a hassle-free and affordable journey tailored to you.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/paket-trip" class="w-full sm:w-auto px-8 py-4 bg-white text-ocean-600 font-bold rounded-full shadow-lg hover:-translate-y-1 transition-all duration-300">
          Lihat Paket Trip
        </a>
        <a href="https://wa.me/6285117480447" target="_blank" class="w-full sm:w-auto px-8 py-4 bg-ocean-500 hover:bg-ocean-400 text-white font-bold rounded-full shadow-lg border border-ocean-400/50 hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2">
           <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.031 0C5.385 0 0 5.385 0 12.031c0 2.12.553 4.116 1.528 5.865L.045 23.366l5.63-1.478A11.968 11.968 0 0012.031 24c6.646 0 12.031-5.385 12.031-12.031S18.677 0 12.031 0zm0 21.986c-1.802 0-3.513-.483-5.01-1.353l-.36-.21-3.715.976.995-3.626-.23-.365a9.954 9.954 0 01-1.554-5.38c0-5.503 4.478-9.98 9.982-9.98 5.49 0 9.966 4.478 9.966 9.982 0 5.503-4.476 9.956-9.966 9.956z" />
          </svg>
          Kontak via WhatsApp
        </a>
      </div>
    </div>
  </section>
</MainLayout>
