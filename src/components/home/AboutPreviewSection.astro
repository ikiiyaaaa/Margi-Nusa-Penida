---
import SectionHeading from '../shared/SectionHeading.astro';
import { useTranslations } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const { lang = 'id' } = Astro.props;
const t = useTranslations(lang as any);
const l = (path: string) => getRelativeLocaleUrl(lang as any, path);
---

<section id="about" class="py-24 bg-white">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Visual Side -->
      <div class="relative">
        <div class="relative rounded-[2rem] overflow-hidden shadow-2xl aspect-[4/5] md:aspect-auto md:h-[600px] z-10">
          <img 
            src="https://images.unsplash.com/photo-1588880628359-25f0ad0869a4?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
            alt="Nusa Penida View" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
        </div>
        
        <!-- Floating Badge -->
        <div class="absolute -bottom-6 -right-6 md:-right-12 bg-white p-6 rounded-2xl shadow-xl z-20 flex items-center gap-4 max-w-[280px]">
          <div class="w-14 h-14 bg-ocean-100 text-ocean-600 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900">{t('why.safe')}</h4>
            <p class="text-sm text-gray-500">{t('about.preview_guides')}</p>
          </div>
        </div>
        
        <!-- Deco element -->
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-ocean-50 rounded-full blur-3xl -z-10"></div>
      </div>

      <!-- Content Side -->
      <div>
        <SectionHeading 
          title={t('about.preview_title')} 
          subtitle={t('nav.about')} 
          centered={false} 
        />
        
        <p class="text-lg text-gray-600 leading-relaxed mb-6 font-light">
          {t('about.preview_desc_1')}
        </p>

        <p class="text-lg text-gray-600 leading-relaxed mb-8 font-light">
          {t('about.preview_desc_2')}
        </p>

        <div class="grid grid-cols-2 gap-6 mb-10">
          <div class="flex flex-col gap-2">
            <span class="text-4xl font-bold font-['Poppins'] text-ocean-600">100+</span>
            <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">{t('about.preview_clients')}</span>
          </div>
          <div class="flex flex-col gap-2">
            <span class="text-4xl font-bold font-['Poppins'] text-sunset-500">Local</span>
            <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">{t('about.preview_guides')}</span>
          </div>
        </div>

        <a href={l('/about-us')} class="inline-flex items-center gap-2 text-ocean-600 font-semibold hover:text-ocean-700 transition-colors group">
          {t('about.preview_cta')}
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
    </div>
  </div>
</section>
