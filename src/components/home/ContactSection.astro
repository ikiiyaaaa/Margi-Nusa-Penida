---
import SectionHeading from '../shared/SectionHeading.astro';
import { useTranslations } from '../../i18n/utils';

interface Props {
  headingTitle?: string;
  headingSubtitle?: string;
  description?: string;
  lang?: string;
}

const { 
  lang = 'id',
  headingTitle,
  headingSubtitle,
  description
} = Astro.props;

const t = useTranslations(lang as any);
---

<section class="py-24 bg-white relative overflow-hidden">
  <!-- Fancy Background Elements -->
  <div class="absolute -top-[20%] -right-[10%] w-[50%] h-[50%] rounded-full bg-ocean-50/50 blur-[120px] -z-10"></div>
  <div class="absolute -bottom-[20%] -left-[10%] w-[50%] h-[50%] rounded-full bg-sunset-50/50 blur-[120px] -z-10"></div>

  <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
    <div class="text-center mb-16">
      <SectionHeading 
        title={headingTitle || t('contact.title')} 
        subtitle={headingSubtitle || t('contact.subtitle')} 
      />
      <p class="text-gray-500 max-w-2xl mx-auto text-lg pt-4">
        {description || t('contact.desc')}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">
      
      <!-- Left Column: Contact Cards -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        
        <!-- Card 1: WhatsApp -->
        <a href="https://wa.me/6285117480447" target="_blank" class="flex items-start gap-6 p-8 bg-white rounded-3xl border border-gray-100 shadow-lg shadow-gray-200/40 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-green-600 group-hover:text-white transition-colors">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{t('contact.whatsapp_phone')}</h3>
            <p class="text-gray-500 font-medium mb-1">0851-1748-0447</p>
            <p class="text-gray-500 font-medium mb-3">0878-6322-9403</p>
            <span class="text-xs font-semibold uppercase tracking-wider text-green-600 bg-green-50 px-3 py-1 rounded-full">{t('contact.available')}</span>
          </div>
        </a>

        <!-- Card 2: Email -->
        <a href="mailto:marginusapenida@gmail.com" class="flex items-start gap-6 p-8 bg-white rounded-3xl border border-gray-100 shadow-lg shadow-gray-200/40 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-14 h-14 bg-ocean-50 text-ocean-600 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-ocean-600 group-hover:text-white transition-colors">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{t('contact.email_us')}</h3>
            <p class="text-gray-500 font-medium mb-3">marginusapenida@gmail.com</p>
            <span class="text-xs font-semibold uppercase tracking-wider text-ocean-600 bg-ocean-50 px-3 py-1 rounded-full">{t('contact.fast_response')}</span>
          </div>
        </a>

        <!-- Card 3: Location -->
        <div class="flex items-start gap-6 p-8 bg-white rounded-3xl border border-gray-100 shadow-lg shadow-gray-200/40 hover:shadow-xl transition-all duration-300 group">
          <div class="w-14 h-14 bg-sunset-50 text-sunset-600 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-sunset-600 group-hover:text-white transition-colors">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="w-full">
            <h3 class="text-xl font-bold text-gray-900 mb-2">{t('contact.office')}</h3>
            <p class="text-gray-500 leading-relaxed mb-4">Nusa Penida, Bali, Indonesia</p>
            <a href="https://maps.app.goo.gl/uP65G3fX7X7X7X7X7" target="_blank" class="inline-flex items-center gap-2 text-sm font-bold text-sunset-600 hover:text-sunset-700 transition-colors">
              {t('contact.view_map')}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column: Direct Message Form -->
      <div class="lg:col-span-7">
        <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-2xl shadow-gray-200/50 border border-gray-100">
          <h3 class="text-2xl font-bold font-['Poppins'] text-gray-900 mb-2">{t('contact.form_title')}</h3>
          <p class="text-gray-500 mb-8">{t('contact.form_desc')}</p>
          
          <form id="waForm" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="name" class="text-sm font-semibold text-gray-700">{t('contact.label_name')}</label>
                <input type="text" id="name" required class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-ocean-500 focus:border-ocean-500 transition-all outline-none" placeholder={t('contact.placeholder_name')}>
              </div>
              <div class="space-y-2">
                <label for="phone" class="text-sm font-semibold text-gray-700">{t('contact.label_wa')}</label>
                <input type="tel" id="phone" required class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-ocean-500 focus:border-ocean-500 transition-all outline-none" placeholder={t('contact.placeholder_wa')}>
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="subject" class="text-sm font-semibold text-gray-700">{t('contact.label_subject')}</label>
              <input type="text" id="subject" required class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-ocean-500 focus:border-ocean-500 transition-all outline-none" placeholder={t('contact.placeholder_subject')}>
            </div>
            
            <div class="space-y-2">
              <label for="message" class="text-sm font-semibold text-gray-700">{t('contact.label_message')}</label>
              <textarea id="message" rows="4" required class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-ocean-500 focus:border-ocean-500 transition-all outline-none resize-none" placeholder={t('contact.placeholder_message')}></textarea>
            </div>
            
            <button type="submit" class="w-full py-4 px-8 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl shadow-lg shadow-green-500/30 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-3 text-lg">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12.031 0C5.385 0 0 5.385 0 12.031c0 2.12.553 4.116 1.528 5.865L.045 23.366l5.63-1.478A11.968 11.968 0 0012.031 24c6.646 0 12.031-5.385 12.031-12.031S18.677 0 12.031 0zm0 21.986c-1.802 0-3.513-.483-5.01-1.353l-.36-.21-3.715.976.995-3.626-.23-.365a9.954 9.954 0 01-1.554-5.38c0-5.503 4.478-9.98 9.982-9.98 5.49 0 9.966 4.478 9.966 9.982 0 5.503-4.476 9.956-9.966 9.956zm5.122-7.252c-.28-.142-1.656-.818-1.916-.91-.258-.095-.448-.142-.64.14-.188.283-.728.91-.89 1.1-.167.188-.334.21-.615.07-.28-.14-1.18-.435-2.25-1.39-.83-.74-1.39-1.655-1.553-1.938-.16-.282-.016-.436.124-.576.126-.126.28-.328.42-.492.14-.165.187-.282.28-.47.094-.188.048-.352-.023-.493-.07-.14-.64-1.545-.875-2.115-.23-.558-.466-.484-.64-.492-.165-.008-.353-.01-.542-.01-.188 0-.493.07-.75.352-.257.282-.98 9.957-.98 2.333s.76 2.65 1.08 3.076c.32.422 2.11 3.22 5.11 4.512.716.308 1.275.492 1.708.63.72.19 1.378.163 1.895.1.58-.07 1.655-.676 1.888-1.328.234-.653.234-1.213.165-1.328-.07-.116-.258-.188-.54-.33z" clip-rule="evenodd" />
              </svg>
              {t('contact.btn_send')}
            </button>
          </form>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('waForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const phone = (document.getElementById('phone') as HTMLInputElement).value;
      const subject = (document.getElementById('subject') as HTMLInputElement).value;
      const message = (document.getElementById('message') as HTMLTextAreaElement).value;
      
      const targetNumber = '6285117480447';
      const textTemplate = "Halo Margi Nusa Penida!%0A%0ANama: {name}%0AWhatsApp: {phone}%0ASubject: {subject}%0A%0A{message}";
      const text = textTemplate
        .replace('{name}', name)
        .replace('{phone}', phone)
        .replace('{subject}', subject)
        .replace('{message}', message);
      
      window.open(`https://wa.me/${targetNumber}?text=${text}`, '_blank');
    });
  }
</script>
