---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '../../i18n/utils';

const { lang = 'id' } = Astro.props;
const t = useTranslations(lang as any);
const l = (path: string) => getRelativeLocaleUrl(lang as any, path);
---

<footer class="bg-gray-900 text-gray-300 pt-16 pb-8 border-t border-gray-800 mt-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand & About -->
      <div class="col-span-1 md:col-span-2">
        <a href={l('/')} class="flex items-center mb-6">
          <img src="/favicon.svg" alt="Margi Nusa Penida Logo" class="h-20 w-auto brightness-0 invert" />
        </a>
        <p class="text-gray-400 leading-relaxed max-w-sm">
          {t('footer.description')}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-6">{t('footer.explore')}</h3>
        <ul class="space-y-4">
          <li><a href={l('/')} class="hover:text-ocean-400 transition-colors">{t('nav.home')}</a></li>
          <li><a href={l('/paket-trip')} class="hover:text-ocean-400 transition-colors">{t('nav.packages')}</a></li>
          <li><a href={l('/about-us')} class="hover:text-ocean-400 transition-colors">{t('nav.about')}</a></li>
          <li><a href={l('/gallery')} class="hover:text-ocean-400 transition-colors">{t('nav.gallery')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-6">{t('footer.contact')}</h3>
        <ul class="space-y-4">
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="https://wa.me/6285117480447" target="_blank" class="hover:text-ocean-400 transition-colors">0851-1748-0447</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:marginusapenida@gmail.com" class="hover:text-ocean-400 transition-colors">marginusapenida@gmail.com</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c.796 0 1.441.645 1.441 1.44s-.645 1.44-1.441 1.44c-.795 0-1.439-.645-1.439-1.44s.644-1.44 1.439-1.44z" />
            </svg>
            <a href="https://www.instagram.com/marginusapenida" target="_blank" class="hover:text-ocean-400 transition-colors">Instagram</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
            <a href="https://www.facebook.com/profile.php?id=61576783696794" target="_blank" class="hover:text-ocean-400 transition-colors">Facebook</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.6-4.12-1.31a6.417 6.417 0 01-1.87-1.55l-.1-.11v7.16c0 1.87-.35 3.66-1.05 5.26a9.427 9.427 0 01-2.85 3.8c-1.54 1.18-3.31 1.91-5.18 2.14-1.87.23-3.76-.02-5.56-.73a9.433 9.433 0 01-4.48-3.99c-1.04-1.85-1.43-3.96-1.12-6.04.31-2.07 1.31-3.99 2.85-5.49 1.54-1.49 3.53-2.52 5.65-2.9 2.11-.38 4.31-.08 6.27.87v4.07c-1.32-.6-2.75-.85-4.19-.73-1.44.12-2.81.71-3.93 1.61-1.12.9-1.91 2.11-2.26 3.49-.35 1.38-.28 2.84.21 4.18.49 1.34 1.41 2.5 2.62 3.3 1.21.8 2.65 1.19 4.1 1.12a6.411 6.411 0 005.15-2.6c.64-.85 1.05-1.81 1.23-2.81.18-1 .18-2.03.02-3.04V.02z" />
            </svg>
            <a href="https://www.tiktok.com/@margi.nusa.penida" target="_blank" class="hover:text-ocean-400 transition-colors">TikTok</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <a href="https://linktr.ee/marginusapenida" target="_blank" class="hover:text-ocean-400 transition-colors">Linktree</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-gray-800 text-sm text-gray-500 flex flex-col md:flex-row justify-between items-center gap-4">
      <p>&copy; {new Date().getFullYear()} Margi Nusa Penida. {t('footer.rights')}</p>
    </div>
  </div>
</footer>
